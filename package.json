{
  "name": "digital-curator-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@10.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "changeset": "changeset"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "~5.8.2"
  }
}
